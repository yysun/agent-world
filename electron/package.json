{
  "name": "@agent-world/electron",
  "description": "Agent World desktop application",
  "productName": "Agent World",
  "author": "yysun",
  "repository": {
    "type": "git",
    "url": "https://github.com/yysun/agent-world.git"
  },
  "homepage": "https://github.com/yysun/agent-world",
  "version": "0.16.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "build": {
    "appId": "com.agentworld.app",
    "productName": "Agent World",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "renderer/dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main.js"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "yysun",
        "repo": "agent-world"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icons/agent-world.icns"
    },
    "win": {
      "icon": "assets/icons/agent-world.ico"
    }
  },
  "scripts": {
    "check": "npx tsc --noEmit --project tsconfig.electron.json",
    "main:build": "npx tsc --project tsconfig.electron.json",
    "main:watch": "npx tsc --project tsconfig.electron.json --watch --preserveWatchOutput",
    "renderer:dev": "vite --config vite.config.js",
    "renderer:build": "vite build --config vite.config.js",
    "postinstall": "electron-builder install-app-deps",
    "electron:dev": "wait-on http://127.0.0.1:5181 file:dist/main.js && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5181 electron --remote-debugging-port=9222 .",
    "dev": "npm-run-all --parallel main:watch renderer:dev electron:dev",
    "start": "npm run main:build && npm run renderer:build && electron .",
    "prepare:runtime": "npm --prefix .. run build:core && node ../scripts/prepare-electron-runtime.js",
    "package:base": "npm run main:build && npm run renderer:build && npm run prepare:runtime",
    "dist:dir": "npm run package:base && electron-builder --dir --publish never",
    "dist:mac": "npm run package:base && electron-builder --mac dmg zip --publish never",
    "dist:win": "npm run package:base && electron-builder --win nsis --x64 --publish never",
    "dist:win:arm64": "npm run package:base && electron-builder --win nsis --arm64 --publish never",
    "dist:all": "npm run dist:mac && npm run dist:win"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "events": "^3.3.0",
    "fast-glob": "^3.3.3",
    "marked": "^17.0.1",
    "nanoid": "^5.1.5",
    "node-cron": "^4.2.1",
    "openai": "^6.15.0",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sqlite3": "^5.1.7",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  }
}